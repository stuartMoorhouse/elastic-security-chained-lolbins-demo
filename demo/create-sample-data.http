### 3. Benign IP — mwilson forgets password, then logs in successfully
# No MFA failures, no post-compromise actions → rule does not fire
POST {{esUrl}}/logs-okta.system-default/_bulk?refresh=true
Authorization: Basic {{esUser}} {{esPassword}}
Content-Type: application/json

{"create":{}}
{"@timestamp":"{{$datetime iso8601 -10 m}}","event":{"action":"user.session.start","outcome":"failure","dataset":"okta.system","category":["authentication"],"kind":"event"},"okta":{"event_type":"user.session.start","outcome":{"result":"FAILURE","reason":"INVALID_CREDENTIALS"}},"source":{"ip":"{{benignIp}}"},"client":{"ip":"{{benignIp}}"},"user":{"name":"mwilson@example.com","email":"mwilson@example.com"},"data_stream":{"dataset":"okta.system","namespace":"default","type":"logs"}}
{"create":{}}
{"@timestamp":"{{$datetime iso8601 -8 m}}","event":{"action":"user.session.start","outcome":"success","dataset":"okta.system","category":["authentication"],"kind":"event"},"okta":{"event_type":"user.session.start","outcome":{"result":"SUCCESS"}},"source":{"ip":"{{benignIp}}"},"client":{"ip":"{{benignIp}}"},"user":{"name":"mwilson@example.com","email":"mwilson@example.com"},"data_stream":{"dataset":"okta.system","namespace":"default","type":"logs"}}
